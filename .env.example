# Brand Extractor Service — environment variable reference
# Copy this file to .env and fill in values for local development.
# Never commit a populated .env file — it is listed in .gitignore.

# ---------------------------------------------------------------------------
# Spring profile
# local  → mock AI, verbose logging (default when unset)
# dev    → real Vertex AI, INFO logging, all health details visible
# prod   → real Vertex AI, JSON logging, management on separate port
# ---------------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=local

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
SERVER_PORT=8080

# Max file upload size (service hard limit is 10 MB; Spring must be >= that)
MAX_UPLOAD_SIZE=10MB
MAX_REQUEST_SIZE=12MB

# ---------------------------------------------------------------------------
# Vertex AI / Gemini
#
# Set VERTEXAI_ENABLED=true and provide a project ID to switch from the mock
# client to real Gemini. GCP Application Default Credentials must also be
# available (see https://cloud.google.com/docs/authentication/provide-credentials-adc).
#
# Quick local setup:
#   gcloud auth application-default login
#   export VERTEXAI_ENABLED=true
#   export VERTEXAI_PROJECT_ID=my-gcp-project
# ---------------------------------------------------------------------------
VERTEXAI_ENABLED=false
VERTEXAI_PROJECT_ID=

# Region that hosts the Vertex AI endpoint (default: us-central1)
VERTEXAI_LOCATION=us-central1

# Gemini model to use (default: gemini-2.0-flash-001)
VERTEXAI_MODEL_ID=gemini-2.0-flash-001

# Generation temperature — 0.0 is fully deterministic (recommended for extraction)
VERTEXAI_TEMPERATURE=0.0

# Maximum tokens in a single Gemini response
VERTEXAI_MAX_OUTPUT_TOKENS=2048

# How many times to retry if Gemini returns malformed JSON (0–5)
VERTEXAI_MAX_PARSE_RETRIES=2

# ---------------------------------------------------------------------------
# GCP credentials (only needed when VERTEXAI_ENABLED=true)
# Point to a service-account key file, or use Workload Identity in GKE/Cloud Run.
# ---------------------------------------------------------------------------
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ---------------------------------------------------------------------------
# Production-only
# ---------------------------------------------------------------------------
# Port for Spring Actuator management endpoints (keeps health/metrics internal)
# MANAGEMENT_PORT=8081
