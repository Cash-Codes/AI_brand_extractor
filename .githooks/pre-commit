#!/usr/bin/env bash
set -e

export JAVA_HOME="${JAVA_HOME:-/usr/local/opt/openjdk@21}"

echo "pre-commit: checking project compiles..."

if ./gradlew compileJava compileTestJava -q 2>&1; then
  echo "pre-commit: compilation OK"
else
  echo "pre-commit: compilation FAILED — fix errors before committing"
  exit 1
fi
